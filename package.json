  "dependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@mantine/carousel": "^5.6.1",
    "@mantine/core": "^5.6.1",
    "@mantine/hooks": "^5.6.1",
    "@react-spring/parallax": "^9.5.5",
    "@tabler/icons-react": "^2.47.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.0",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "embla-carousel-react": "^7.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^6.2.0",
    "react-router-dom": "^6.4.3",
    "react-scripts": "^5.0.1",
    "react-three-fiber": "^6.0.13",
    "react-tsparticles": "^2.5.3",
    "three": "^0.146.0",
    "tsparticles": "^2.5.3",
    "tsparticles-engine": "^2.12.0",
    "typescript": "^4.8.4",
    "typewriter-effect": "^2.19.0"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --passWithNoTests",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,public}/**/*.{ts,tsx,js,jsx,css,md,json}\" \"*.{md,json}\"",
    "format:check": "prettier --check \"{src,public}/**/*.{ts,tsx,js,jsx,css,md,json}\" \"*.{md,json}\"",
    "check": "npm run lint && npm run typecheck && npm run test:ci",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/react-pdf": "^5.7.4",
    "@types/three": "^0.146.0",
    "gh-pages": "^4.0.0",
    "prettier": "^3.6.2"
  }
